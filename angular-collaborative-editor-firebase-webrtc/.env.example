# Firebase configuration (copy to environment.ts)
#
# Create a project at https://console.firebase.google.com/
# Add a Web app and paste the config values below.

FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Enable Anonymous Authentication and Cloud Firestore in the Firebase console.
# Create a Firestore database in test mode for local development.
